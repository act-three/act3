FROM golang:alpine

# Core system packages: shell, VCS, networking, certs, editors
RUN apk add --no-cache \
	bash \
	ca-certificates \
	curl \
	git \
	gnupg \
	jq \
	less \
	ripgrep \
	mandoc \
	openssh-client \
	openssh-server \
	rsync \
	sqlite \
	tzdata \
	vim \
	zsh

# Video processing (dev builds; deploy.sh builds its own static ffmpeg)
RUN apk add --no-cache \
	ffmpeg

# Node.js — required by Playwright MCP server (not used for project builds)
RUN apk add --no-cache nodejs npm

# Non-root user (unlock account so sshd allows pubkey auth)
RUN addgroup -g 501 dev && adduser -u 501 -G dev -h /home/dev -s /bin/bash -D dev \
	&& passwd -u dev

# Claude Code CLI (native installer)
USER dev
RUN curl -fsSL https://claude.ai/install.sh | bash
USER root

# sqlc — SQL code generator
RUN GOBIN=/usr/local/bin go install github.com/sqlc-dev/sqlc/cmd/sqlc@v1.30.0

RUN GOBIN=/usr/local/bin go install golang.org/x/tools/cmd/goimports@latest

# shfmt — shell formatter
RUN GOBIN=/usr/local/bin go install mvdan.cc/sh/v3/cmd/shfmt@latest

# dprint — JS/CSS/JSON/SQL/shell formatter
RUN curl -fsSL https://dprint.dev/install.sh | DPRINT_INSTALL=/usr/local sh

# System-wide environment for login shells (/etc/profile sources this)
RUN printf '%s\n' \
	'export PATH=$HOME/.local/bin:/usr/local/go/bin:$PATH' \
	'export GOEXPERIMENT=jsonv2' \
	'export A3STORAGE=/home/dev/.local/act3' \
	> /etc/profile.d/act3.sh

# SSH server setup
RUN ssh-keygen -A

# BASH_ENV makes non-interactive bash (e.g. ssh host "cmd") source
# /etc/profile, so all sessions get the same environment as login shells.
RUN printf '%s\n' \
	'SetEnv BASH_ENV=/etc/profile' \
	>> /etc/ssh/sshd_config
RUN mkdir -p /home/dev/.ssh && chmod 700 /home/dev/.ssh \
	&& ssh-keyscan github.com >> /home/dev/.ssh/known_hosts \
	&& chown -R dev:dev /home/dev
EXPOSE 22

# BASH_ENV makes docker exec bash sessions source /etc/profile
# (same as SSH via SetEnv above).
ENV BASH_ENV=/etc/profile

# Default working directory
WORKDIR /home/dev

CMD ["/usr/sbin/sshd", "-D", "-e"]
