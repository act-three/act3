FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
	chromium \
	fonts-liberation \
	&& rm -rf /var/lib/apt/lists/*

# Run as non-root
RUN useradd -m chrome
USER chrome

ENTRYPOINT ["chromium", \
	"--headless", \
	"--no-sandbox", \
	"--disable-gpu", \
	"--disable-dev-shm-usage", \
	"--remote-debugging-port=9222"]
