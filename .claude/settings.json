{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs goimports -w",
            "name": "Run goimports on Go files",
            "filter": "endswith('.go')"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-query-sort.sh\"",
            "name": "Check query.sql sort order",
            "filter": "endswith('database/query.sql')"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null && go generate ./database",
            "name": "Run sqlc after schema changes",
            "filter": "contains('database/ddl/') or contains('database/query.sql') or contains('database/sqlc.json')"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null && go generate . 2>/dev/null",
            "name": "Rebuild CSS/JS bundles",
            "filter": "endswith('.js') or endswith('.css') or (contains('/ui/') and endswith('.go')) or (contains('/view/') and endswith('.go'))"
          }
        ]
      }
    ]
  }
}
